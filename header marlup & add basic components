<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <style>

    body {
      background-color: rgb(245, 245, 220);
      font-family: "Inter", sans-serif;
      line-height: 1.5;
    }

    .main-header {
      background-color: rgb(245, 245, 220);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1.5rem;
      border-bottom: 1px solid rgba(100, 100, 80, 0.2);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .logo__img {
      height: 48px;
      width: auto;
      border-radius: 12px;
    }

    .logo__text {
      font-size: 1.6rem;
      font-weight: 700;
      background: linear-gradient(135deg, #2c5a2a, #4e8d3b);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .main-nav ul {
      display: flex;
      list-style: none;
      gap: 3rem;
      flex-wrap: wrap;
    }

    .main-nav a {
      text-decoration: none;
      font-size: 1rem;
      font-weight: 500;
      color: #2f4d2d;
      transition: color 0.2s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .main-nav a:hover {
      color: #1e6b1a;
    }

    .nav-icon {
      width: 15px;
      height: 15px;
      display: inline-block;
      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
    }

.icon-home {    
  background-image: url('https://cdn-icons-png.flaticon.com/128/3917/3917033.png');    
}    
.icon-new {    
  background-image: url('https://cdn-icons-png.flaticon.com/128/3917/3917618.png');    
}    
.icon-sale {    
  background-image: url('https://cdn-icons-png.flaticon.com/128/3916/3916598.png');    
}    
.icon-more {    
  background-image: url('https://cdn-icons-png.flaticon.com/128/3916/3916585.png');    
}    
.icon-contact {    
  background-image: url('https://cdn-icons-png.flaticon.com/128/3917/3917567.png');    
}

    .main-header__actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 0.6rem 1.2rem;
      border-radius: 20px;
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: all 0.2s ease;
      cursor: pointer;
    }

    .btn--primary {
      background-color: #2c5a2a;
      color: white;
      border: 1px solid #2c5a2a;
    }

    .btn--primary:hover {
      background-color: #1e461c;
      transform: translateY(-2px);
    }

    .btn--secondary {
      background-color: #e8e6d5;
      color: #2c5a2a;
      border: 1px solid #c0c0a8;
    }

    .btn--secondary:hover {
      background-color: #dddcc8;
      transform: translateY(-2px);
    }

    }

    }
  </style>
</head>
<body>
  <header class="main-header">
    <a href="/" class="logo">
      <img class="logo__img" src="7d28355ae55210429e7558b8a615a91c.jpg" alt="Main logo">
      <span class="logo__text">Main logo</span>
    </a>
    
    <nav class="main-nav">
      <ul>
        <li><a href="#"><span class="nav-icon icon-home"></span> Головна</a></li>
        <li><a href="#"><span class="nav-icon icon-new"></span> Новинки</a></li>
        <li><a href="#"><span class="nav-icon icon-sale"></span> Акції</a></li>
        <li><a href="#"><span class="nav-icon icon-more"></span> Більше</a></li>
        <li><a href="#"><span class="nav-icon icon-contact"></span> Контакти</a></li>
      </ul>
    </nav>

      <a href="#" class="btn btn--primary">Button</a>
      <a href="#" class="btn btn--secondary">Button</a>
    </div>
  </header>

</body>
</html>
